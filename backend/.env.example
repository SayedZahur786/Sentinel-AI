# Supabase direct host (db.<ref>.supabase.co) is IPv6-only. On IPv4 networks use the
# Session Pooler string instead: postgresql+psycopg://postgres.<ref>:<pw>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql+psycopg://postgres:password@db.example.supabase.co:5432/postgres?sslmode=require
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
FRONTEND_ORIGINS=http://localhost:5173
AI_MOCK_MODE=true
